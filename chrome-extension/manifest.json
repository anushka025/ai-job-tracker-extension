{
  "manifest_version": 3,
  "name": "JobTracker Pro",
  "version": "1.0.0",
  "description": "Save LinkedIn jobs to your dashboard with one click",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://jobtrackerpro.vercel.app/*"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs*",
        "https://www.linkedin.com/jobs/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}